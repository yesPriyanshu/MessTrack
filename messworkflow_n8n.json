    {
      "parameters": {
        "jsCode": "// extract all row numbers\nconst rowNumbers = items.map(item => item.json.row_number);\n\n// find latest row\nconst lastRowNumber = Math.max(...rowNumbers);\n\n// ignore header row if present (optional)\nconst reviewCount = lastRowNumber - 1;\n\n// check trigger condition\nconst shouldRunAI =\n  reviewCount >= 5 &&\n  reviewCount % 5 === 0;\n\n// attach metadata WITHOUT losing original rows\nreturn items.map(item => {\n  return {\n    json: {\n      ...item.json,\n      lastRowNumber,\n      reviewCount,\n      shouldRunAI\n    }\n  };\n});"
      },
