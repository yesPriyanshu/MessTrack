    {
      "parameters": {
        "jsCode": "// AI response (normally comes from previous node)\nconst ai = {\n  TopMeal: \"Dinner - Roti + Dal + Rice · Paneer\",\n  BadMeal: \"Breakfast - Sandwich + Banana\",\n  Summary: \"On 18th April 2026, the dinner meal received the highest rating of 5/5 due to its flavor and satisfying combination of ingredients. The breakfast meal rated only 3/5, with students mentioning that the sandwich was bland and insufficient for a morning meal.\",\n  FoodSuggestion: \"To improve the mess menu, incorporating more variety in breakfast options like omelets or smoothies could enhance student satisfaction. Additionally, adding a wider range of vegetarian and non-vegetarian curries for lunch could appeal to diverse tastes.\"\n};\n\n// Extract date from summary automatically\nconst dateMatch = ai.Summary.match(/On\\s(.+?),/);\nconst reportDate = dateMatch ? dateMatch[1] : \"Today\";\n\n// Subject line\nconst subject = `Mess Menu Performance Report – ${reportDate}`;\n\n// Email HTML template\nconst html = `\n<div style=\"font-family:Arial,Helvetica,sans-serif;background:#f9fafb;padding:24px;\">\n  <div style=\"max-width:640px;margin:auto;background:#ffffff;border-radius:12px;padding:24px;border:1px solid #e5e7eb;\">\n    \n    <h2 style=\"margin-bottom:6px;color:#111827;\">🍽 Mess Feedback Analysis Report</h2>\n    <p style=\"color:#6b7280;margin-top:0;\">Date: ${reportDate}</p>\n\n    <hr style=\"border:none;border-top:1px solid #e5e7eb;margin:20px 0;\" />\n\n    <h3 style=\"color:#16a34a;\">⭐ Top Performing Meal</h3>\n    <p style=\"font-size:16px;color:#111827;margin-top:4px;\">\n      ${ai.TopMeal}\n    </p>\n\n    <h3 style=\"color:#dc2626;margin-top:20px;\">⚠ Needs Improvement</h3>\n    <p style=\"font-size:16px;color:#111827;margin-top:4px;\">\n      ${ai.BadMeal}\n    </p>\n\n    <h3 style=\"color:#2563eb;margin-top:20px;\">📊 Summary</h3>\n    <p style=\"font-size:15px;color:#374151;line-height:1.6;\">\n      ${ai.Summary}\n    </p>\n\n    <h3 style=\"color:#9333ea;margin-top:20px;\">💡 Suggested Improvements</h3>\n    <p style=\"font-size:15px;color:#374151;line-height:1.6;\">\n      ${ai.FoodSuggestion}\n    </p>\n\n    <hr style=\"border:none;border-top:1px solid #e5e7eb;margin:24px 0;\" />\n\n    <p style=\"font-size:12px;color:#9ca3af;\">\n      Generated automatically by Hostel Mess AI Analytics System\n    </p>\n\n  </div>\n</div>\n`;\n\n// Return structured JSON\nreturn [\n  {\n    json: {\n      Subject: subject,\n      HTML: html,\n      SUMMARY: ai.Summary\n    }\n  }\n];"
      },
