            {
              "role": "system",
              "content": "You are a professional food rating analyser. \nRespond ONLY with a raw JSON object. \nNo markdown. No code fences. No backticks. No explanation. \nStart your response directly with { and end with }."
            },
            {
              "content": "={{ $json.Prompt }}"
            }
          ]
        },
